# Supabase Configuration
# Copy this file to .env.local and fill in your values
# DO NOT commit .env.local to git!

# Get these from your Supabase project settings: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://[your-project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=[your-anon-key]

# Service Role Key - NEVER expose this to the client!
# Get from: https://app.supabase.com/project/_/settings/api
# Only use in Server Actions and API routes
SUPABASE_SERVICE_ROLE_KEY=[your-service-role-key]

# Site Configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# API keys can be set here OR in the dashboard: Admin → Settings → API & Integrations.
# Dashboard values override these. Secrets are stored securely (server-only).
# -----------------------------------------------------------------------------

# PayPal (donation payments)
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_API_BASE=https://api-m.sandbox.paypal.com

# Flutterwave (Card & M-Pesa)
NEXT_PUBLIC_FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-xxxxxxxxxx-X

# Stripe (optional)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# Google Places API (testimonials)
GOOGLE_PLACES_API_KEY=

# Resend (mentor application + contact form emails)
RESEND_API_KEY=
MENTOR_NOTIFICATION_EMAIL=chosenarrowsfoundation@gmail.com
CONTACT_FORM_EMAIL=chosenarrowsfoundation@gmail.com
RESEND_FROM_DOMAIN=onboarding@resend.dev
RESEND_FROM_NAME=Chosen Arrows Foundation

# Optional: Analytics, etc.
# NEXT_PUBLIC_GA_ID=[google-analytics-id]
